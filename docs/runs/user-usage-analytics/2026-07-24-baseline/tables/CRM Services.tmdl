/// Description:
/// 
/// Reference table containing the complete list of all available CRM services across the platform, regardless of whether they have recorded user activity. Used as the primary dimension for CRM service analysis to ensure all services are visible in reports — including those with zero active users. Connect to PostHog Application Usage Events via CRM Service Name.
/// Business Logic:
/// 
/// Acts as a dimension table for CRM service filtering and visualization. Enables reports to display all available CRM services including those with no activity in the selected period. Relationship to PostHog Application Usage Events is one-to-many on CRM Service Name with single cross-filter direction.
/// Usage:
/// 
/// Always use CRM Service Name from this table as the Y axis or filter dimension in service-level visuals. Do not use CRM Service Name from PostHog Application Usage Events directly in visuals — that approach will hide services with zero activity.
table 'CRM Services'
	lineageTag: 90b64a7c-cbb2-4584-aa16-78f80d54e66b

	column 'CRM Service Name'
		lineageTag: 92126d38-357c-4ed7-965e-3ab30054f29c
		summarizeBy: none
		isNameInferred
		sourceColumn: [CRM Service Name]

		annotation SummarizationSetBy = Automatic

	partition 'CRM Services' = calculated
		mode: import
		source =
				
				DATATABLE(
				    "CRM Service Name", STRING,
				    {
				        {"Cloud CRM"},
				        {"GeoForce"},
				        {"Cycle Plan"},
				        {"Admin Tool"},
				        {"Power BI Reports"},
				        {"Routes"},
				        {"Survey"},
				        {"Consent Manager"},
				        {"Data Change Request"},
				        {"Not identified"}
				    }
				)

	annotation PBI_Id = 5753ee21e3584d4a8b879e4e494ab82a

