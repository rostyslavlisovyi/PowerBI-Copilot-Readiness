			```
		displayFolder: CRM Analytics
		lineageTag: 9c699533-b282-47b6-a110-1ce9585c6ab1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MAU Previous Week' =
			VAR _RefDate = [Reference Date]
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('PostHog Application Usage Events'[User Identifier]),
			    DATESINPERIOD('Calendar'[Date], _RefDate - 7, -30, DAY)
			)
		formatString: 0
		displayFolder: WoW Comparison
		lineageTag: 7b9f5d0b-be0b-4151-a5d6-9ede9c3d0bea

	measure 'Weekly Active Users (Calendar)' =
			
			CALCULATE (
			    DISTINCTCOUNT ( 'PostHog Application Usage Events'[User Identifier] ),
			    ALLEXCEPT ( 'Calendar', 'Calendar'[Week] )
			)
		formatString: 0
		displayFolder: WoW Comparison
		lineageTag: c6b9dc45-0820-4320-a923-1078e27f1fc8

	measure 'Weekly Active Users (Calendar) Previous Week' =
			
			VAR _CurrentWeek = MAX ( 'Calendar'[Week] )
			RETURN
			    CALCULATE (
			        [Weekly Active Users (Calendar)],
			        ALL ( 'Calendar' ),
			        'Calendar'[Week] = _CurrentWeek - 7
			    )
		formatString: 0
		displayFolder: WoW Comparison
		lineageTag: 95260ab5-b249-4a8f-8444-e87bd4030f55

	measure 'Reference Date' = MAX ( 'Calendar'[Date] )
		isHidden
		displayFolder: Report Helpers
		lineageTag: 7126a8db-7c4c-4796-bb8d-fc309feda5e4

	measure 'Listed Rows' = ```
			COUNTROWS(
			    SUMMARIZE(
			        'PostHog Application Usage Events',
			        
			        'PostHog Application Usage Events'[User Email]
			        
			    )
			)
			```
