	measure 'Avg Events Previous Period' = ```
			
			VAR PeriodLength = 
			    DATEDIFF(MIN(Calendar[Date]), MAX(Calendar[Date]), DAY) + 1
			RETURN
			    IF(
			        PeriodLength <= 30,
			        CALCULATE(
			            [Avg Events per User],
