	/// Description
	/// The unique numeric identifier of the Power BI embedded report accessed by the user. Used as the relationship key between PostHog Power BI Usage Events and Power BI Report Mapping table. Enables enrichment of usage events with report name and client instance information. Hidden from reports — use Report Name from Power BI Report Mapping for display purposes.
	/// 
	/// Business Logic
	/// Each value corresponds to a specific Power BI embedded report as defined in the Power BI Report Mapping table. The relationship is many-to-one — multiple usage events may reference the same report ID. Use this field to join Power BI usage data with report metadata for analysis by report name or client instance.
	/// 
	/// Usage
	/// Do not use this column directly in report visuals — it is a technical relationship key. Use Report Name from Power BI Report Mapping instead for all display and filtering purposes. Required for the relationship between PostHog Power BI Usage Events and Power BI Report Mapping to function correctly.
	column 'Report ID'
		dataType: int64
		formatString: 0
		displayFolder: Event Info
		lineageTag: 17c13515-893a-48e6-af23-215efb01434b
		summarizeBy: count
		sourceColumn: Report ID

		annotation SummarizationSetBy = Automatic

	column Country
		dataType: string
		lineageTag: 67711058-3125-42a0-850e-2aab8f12e7f5
		summarizeBy: none
		sourceColumn: Country

		annotation SummarizationSetBy = Automatic

	column City
		dataType: string
