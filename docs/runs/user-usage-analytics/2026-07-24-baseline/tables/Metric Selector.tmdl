/// Field parameter table that powers the metric switching slicer on the Overview report page. Enables users to dynamically switch between key user activity metrics — Daily Active Users (DAU), Weekly Active Users (WAU), Monthly Active Users (MAU), and Stickiness (DAU/MAU ratio) — across all Overview report visuals.
table 'Metric Selector'
	lineageTag: cf43acd3-3bcb-4190-b757-589b0429c7e0

	/// Display name of the metric shown in the slicer (DAU, WAU, MAU, DAU/MAU). Select a value to dynamically switch the active metric across all Overview report visuals.
	column Field
		lineageTag: 8feaba0d-531e-468c-a33b-1fdc7d563b30
		summarizeBy: none
		sourceColumn: [Value1]
		sortByColumn: Order

		relatedColumnDetails
			groupByColumn: ParametersFields

		annotation SummarizationSetBy = Automatic

	/// Auto-generated technical column by Power BI Field Parameters. Contains NAMEOF references to source measures. Hidden from reports.
	column ParametersFields
		isHidden
		lineageTag: cf06331a-4f37-4576-b72d-6465fe60ee9a
		summarizeBy: none
		sourceColumn: [Value2]
		sortByColumn: Order

		extendedProperty ParameterMetadata =
				{
				  "version": 3,
				  "kind": 2
				}

		annotation SummarizationSetBy = Automatic

	/// Technical sort order for metric display sequence in the slicer. Hidden from reports.
	column Order
		isHidden
		formatString: 0
		lineageTag: a0f87f70-1f1d-45ad-81db-da274f8ef22b
		summarizeBy: sum
		sourceColumn: [Value3]

		annotation SummarizationSetBy = Automatic

	partition 'Metric Selector' = calculated
		mode: import
		source =
				{
				    ("DAU", NAMEOF('_Measures'[Daily Active Users]), 0),
				    ("WAU", NAMEOF('_Measures'[Weekly Active Users]), 1),
				    ("MAU", NAMEOF('_Measures'[Monthly Active Users]), 2),
				    ("Stickiness WAU/MAU", NAMEOF('_Measures'[Stickiness WAU/MAU]), 3)
				}

	annotation PBI_Id = a158adab16784ff9be3494839f8a6a97

