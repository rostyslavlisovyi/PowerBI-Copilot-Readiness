			        },
			        {
			          "Shows the percentage change in Daily Active Users compared to the same day last week. Positive values indicate growth; negative values indicate decline. Use this measure on the Overview dashboard KPI card to provide immediate context on whether daily user activity is trending up or down.": {
			            "State": "Deleted",
			            "LastModified": "2026-07-02T15:15:28.755Z"
			          }
			        },
			        {
			          "Business Logic:": {
			            "State": "Deleted",
			            "LastModified": "2026-07-02T15:15:28.755Z"
			          }
			        },
			        {
			          "Divides DAU WoW Change by DAU Previous Week using safe division with 0 as fallback when no previous week data is available. Returns 0 at the start of the data window when prior week baseline does not exist.": {
			            "State": "Deleted",
			            "LastModified": "2026-07-02T15:15:28.755Z"
			          }
			        },
			        {
			          "Usage:": {
			            "State": "Deleted",
			            "LastModified": "2026-07-02T15:15:28.755Z"
			          }
			        },
			        {
			          "Use as the primary week-over-week indicator on the DAU KPI card. Display with arrow indicators — green upward arrow for positive": {
			            "State": "Deleted",
			            "LastModified": "2026-07-02T15:15:28.755Z"
			          }
			        },
			        {
			          "red downward arrow for negative. Combine with DAU WoW Change for absolute context.": {
