/// Central date table used for time intelligence across all reports. Supports filtering and grouping by day, week, month, and custom periods. Mark as the official date table to enable DAX time intelligence functions.
table Calendar
	lineageTag: 37be4573-fa28-4395-a24d-99a3b602bdd9
	dataCategory: Time

	/// The primary date key of the Calendar table. Used as the relationship key to PostHog Application Usage Events and as the axis in all time-series visuals. Always use this column for date filtering and time intelligence calculations.
	column Date
		isKey
		formatString: General Date
		displayFolder: Date Filters
		lineageTag: ab0e73c5-f3df-4ec0-88c3-2c1689fec77d
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	/// The first day of the month for each calendar date. Used for monthly grouping and aggregation in trend charts and month-over-month analysis.
	column MonthDate = DATE(YEAR('Calendar'[Date]),MONTH('Calendar'[Date]),1)
		formatString: General Date
		displayFolder: Date Attributes
		lineageTag: e5003ecd-f54a-4c61-bcec-ebe425c2f0b5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// The start date of the ISO week (Monday) for each calendar date. Used for weekly grouping and aggregation in trend charts and week-over-week analysis.
	column Week = 'Calendar'[Date]-WEEKDAY('Calendar'[Date],2)+1
		formatString: General Date
		displayFolder: Date Attributes
		lineageTag: 625c9176-03e6-4fcb-bc9b-fe651700299c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// A text label that returns Last 7 days for dates falling within the 7 complete days prior to today, and blank for all other dates. Used as a filter or slicer to quickly isolate the last 7 days without manual date selection.
	column Last7Days =
			
			var MinDate = TODAY()-7
			var maxDate = TODAY()-1
			RETURN SWITCH(TRUE(),'Calendar'[Date]>=MinDate&&'Calendar'[Date]<=maxDate,"Last 7 days",BLANK())
		displayFolder: Date Filters
		lineageTag: 5447c44f-e032-4135-a059-1ac732ae4d72
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// The last date of the month for each calendar date. Used for month-end reporting and period boundary calculations.
	column EndOfMonth = ENDOFMONTH('Calendar'[Date])
		formatString: General Date
		displayFolder: Date Attributes
		lineageTag: 0d6b8d19-0a50-487e-963f-b107e895a92a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// The day of the week as a number (1=Sunday through 7=Saturday) based on the WEEKDAY function. Used internally for Weekday calculation. Consider hiding if not used directly in visuals.
	column Day = WEEKDAY('Calendar'[Date])
		isHidden
		formatString: 0
		displayFolder: Date Attributes
		lineageTag: 204628b6-8496-480b-8731-a56ed23f80eb
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Classifies each date as workday or weekend based on the day of the week. Sunday (Day=1) and Saturday (Day=7) are classified as weekend; all other days as workday. Use this column to filter or compare CRM activity between working days and weekends.
	column Weekday = IF('Calendar'[Day]=1||'Calendar'[Day]=7,"weekend","workday")
		displayFolder: Date Attributes
		lineageTag: 99325743-072c-4e2a-801f-46edeec66948
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// A formatted text label representing the full date range of the calendar week. Displays the start and end dates of each week in DD MMM format (for example, 02 Jun – 08 Jun). Use this column as the X axis label in weekly trend charts to clearly communicate the reporting period for each bar.
	/// 
	/// Business Logic:
	/// Calculated from the Week column (Monday start date) by adding 6 days to derive the Sunday end date. Both dates are formatted as DD MMM for readability. Each date in the same week shares the same Week Label value.
	/// 
	/// Usage:
	/// Use as the X axis in weekly bar or column charts instead of the raw Week date column. Provides immediately readable week boundaries without requiring users to interpret date numbers. Sort by Calendar[Week] to ensure correct chronological order.
	column 'Week Label' =
			
			VAR _WeekStart = 'Calendar'[Week]
			VAR _WeekEnd = 'Calendar'[Week] + 6
			RETURN
			    FORMAT ( _WeekStart, "DD MMM" ) & " – " & FORMAT ( _WeekEnd, "DD MMM" )
		displayFolder: Date Attributes
		lineageTag: 4cb40f56-bfdd-4c32-8ee9-3375881f443d
		summarizeBy: none
		sortByColumn: Week

		annotation SummarizationSetBy = Automatic

	column 'Is Complete Week' =
			
			VAR _LastDataDate = MAX ( 'Calendar'[Date] ) - 1
			RETURN
			    IF ( 'Calendar'[Week] + 6 <= _LastDataDate, TRUE (), FALSE () )
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 999a9c77-84c4-4f24-afad-73bc1b601975
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source = CALENDAR(MIN('PostHog Application Usage Events'[Event date]), MAX('PostHog Application Usage Events'[Event date]))

	annotation PBI_Id = b0a648d212a9451e96eee8d09f54c3f0

