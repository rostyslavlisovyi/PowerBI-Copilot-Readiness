/// Field parameter table that powers the dimension switching slicer on the Overview report page. Enables users to dynamically change the breakdown dimension across all visuals between Country, CRM Instance, Platform, and Operating System without modifying the report layout.
table 'Dimension Selector'
	lineageTag: 0254d1dd-437a-491c-a9dd-f9ea30c7d56c

	/// Display name of the dimension shown in the slicer (Country, Instance, Platform, OS). Select a value to dynamically switch the breakdown dimension across all Overview report visuals.
	column Field
		lineageTag: 8081acbb-c265-41fd-8025-eda0ccdeac85
		summarizeBy: none
		sourceColumn: [Value1]
		sortByColumn: Order

		relatedColumnDetails
			groupByColumn: ParametersFields

		annotation SummarizationSetBy = Automatic

	/// Auto-generated technical column by Power BI Field Parameters. Contains NAMEOF references to source columns. Hidden from reports.
	column ParametersFields
		isHidden
		lineageTag: 91d394d3-8b94-49a2-9c5b-b2a6b0916576
		summarizeBy: none
		sourceColumn: [Value2]
		sortByColumn: Order

		extendedProperty ParameterMetadata =
				{
				  "version": 3,
				  "kind": 2
				}

		annotation SummarizationSetBy = Automatic

	/// Technical sort order for dimension display sequence in the slicer. Hidden from reports.
	column Order
		isHidden
		formatString: 0
		lineageTag: 1276c060-68a1-4aea-99fa-07e83b166534
		summarizeBy: sum
		sourceColumn: [Value3]

		annotation SummarizationSetBy = Automatic

	partition 'Dimension Selector' = calculated
		mode: import
		source =
				{
				    ("Country", NAMEOF('PostHog Application Usage Events'[Country]), 0),
				    ("Instance", NAMEOF('PostHog Application Usage Events'[CRM Instance Name]), 1),
				    ("Platform", NAMEOF('PostHog Application Usage Events'[Platform]), 2)
				    --,
				    --("Operation System", NAMEOF('PostHog Application Usage Events'[Operating System]), 3)
				}

	annotation PBI_Id = b1f2fd0b461b4768a774e4f60ffbe843

